@article{xuAnalysisCDNP2P2006,
	title = {Analysis of a {CDN}–{P2P} hybrid architecture for cost-effective streaming media distribution},
	volume = {11},
	copyright = {http://www.springer.com/tdm},
	issn = {0942-4962, 1432-1882},
	url = {http://link.springer.com/10.1007/s00530-006-0015-3},
	doi = {10.1007/s00530-006-0015-3},
	abstract = {To distribute video and audio data in real-time streaming mode, two different technologies – Content Distribution Network (CDN) and Peer-to-Peer (P2P) – have been proposed. However, both technologies have their own limitations: CDN servers are expensive to deploy and maintain, and consequently incur a cost for media providers and/or clients for server capacity reservation. On the other hand, a P2P-based architecture requires sufﬁcient number of seed supplying peers to jumpstart the distribution process. Compared with a CDN server, a peer usually offers much lower out-bound streaming rate and hence multiple peers must jointly stream a media data to a requesting peer. Furthermore, it is not clear how to determine how much a peer should contribute back to the system after receiving the media data, in order to sustain the overall media distribution capacity.},
	language = {en},
	number = {4},
	urldate = {2025-11-04},
	journal = {Multimedia Systems},
	author = {Xu, Dongyan and Kulkarni, Sunil Suresh and Rosenberg, Catherine and Chai, Heung-Keung},
	month = apr,
	year = {2006},
	pages = {383--399},
	file = {PDF:files/19/Xu et al. - 2006 - Analysis of a CDN–P2P hybrid architecture for cost-effective streaming media distribution.pdf:application/pdf},
}

@book{meskovicContentDeliveryArchitectures2012,
	title = {Content {Delivery} {Architectures} for {Live} {Video} {Streaming}: {Hybrid} {CDN}-{P2P} as the best option},
	isbn = {78-1-61208-192-2},
	url = {https://personales.upv.es/thinkmind/dl/conferences/ctrq/ctrq_2012/ctrq_2012_2_10_10086.pdf},
	abstract = {In the last years, with the help of high-speed and broadband networking, the content delivery service has been grown up widely. There are a lot of providers for online streaming via Content Delivery Network (CDN), Peer to Peer (P2P) network or hybrid CDN-P2P system. In this paper, we analyse a hybrid solution for real-time streaming: hybrid CDNP2P mechanism that takes the best of both CDN and P2P content delivery architectures. By adapting the best of breed of both worlds (CDN and P2P), we detail a hybrid model which, thorough quantative analysis, shows the benefits of merging the two architectures. Through simulation, we will show that a hybrid CDN-P2P approach is a much more stable platform whilst at the same time a very cost effective approach in providing a live streaming service to the masses.},
	language = {en},
	author = {Meskovic, Melika and Bajric, Himzo and Kos, Mladen},
	year = {2012},
	file = {PDF:files/23/Meskovic et al. - 2012 - Content Delivery Architectures for Live Video Streaming Hybrid CDN-P2P as the best option.pdf:application/pdf},
}

